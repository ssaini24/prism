# GitHub — use App credentials (recommended) OR a personal token as fallback
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub App (comments post as "prism-reviewer[bot]" with its own avatar)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Personal token fallback (used only when App credentials are not set)
# GITHUB_TOKEN=ghp_your_personal_access_token_here

# LLM provider — set to "openai" or "anthropic" or "claude-code" (use local claude binary)
LLM_PROVIDER=anthropic
LLM_MAX_TOKENS=2048

# OpenAI (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your_openai_key_here
# LLM_MODEL=gpt-4o-mini

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your_api_key_here
LLM_MODEL=claude-haiku-4-5-20251001

# Feature flags
ENABLE_CODE_REVIEW=false
ENABLE_ORM_REVIEW=false
ENABLE_DB_EXPLAIN=false

# MySQL read-only connection for EXPLAIN analysis
# Not used when LLM_PROVIDER=claude-code as mysql mcp is integrated into claude.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=prism_readonly
DB_PASSWORD=
DB_NAME=your_database

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
